# Server
PORT=8080

# Redis (use Upstash for production)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OIDC Authentication (get these from the OIDC Developer Portal)
OIDC_CLIENT_ID=your_client_id_here
OIDC_CLIENT_SECRET=your_client_secret_here
OIDC_SERVER_URL=http://localhost:9005
OIDC_REDIRECT_URI=http://localhost:8080/callback
